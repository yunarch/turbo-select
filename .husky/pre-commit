. "$(dirname -- "$0")/common.sh"

# Get a list of staged files (ACMR: Added, Copied, Modified, Renamed)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Lint the staged files
set +e
lint_output=$(bun run lint:code $STAGED_FILES 2>&1)
lint_exit_code=$?
set -e
echo "$lint_output"
if echo "$lint_output" | grep -q "No files found to lint."; then
  echo "Skipping lint: no files matched."
fi

# Format the staged files
bun run format:all $STAGED_FILES