{
  "$schema": "https://json.schemastore.org/package",
  "name": "@yunarch/turbo-select",
  "version": "0.0.1",
  "description": "A CLI tool to filter and select packages from the Turborepo package list and run a script command.",
  "license": "MIT",
  "keywords": [
    "turbo",
    "turborepo",
    "monorepo",
    "cli",
    "tool",
    "select",
    "filter",
    "packages",
    "scripts",
    "environment",
    "mode"
  ],
  "author": {
    "name": "Adrian Lopez Gonzalez",
    "url": "https://github.com/yunarch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yunarch/turbo-select.git"
  },
  "bugs": {
    "url": "https://github.com/yunarch/turbo-select/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "README.md",
    "LICENSE.md",
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "turbo-select": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky && bun run gen",
    "gen": "bun run ./scripts/docsgen.ts",
    "lint": "bun run --parallel lint:code lint:ts",
    "lint:code": "oxlint",
    "lint:ts": "tsc --noEmit",
    "format": "oxfmt format --check ./",
    "format:all": "oxfmt format --write ./",
    "clean": "rimraf dist .turbo tests/__fixture__/.turbo",
    "build": "bun build ./src/index.ts --outdir ./dist --minify --target node --format esm --external commander --external nano-spawn --external @inquirer/select",
    "tests": "bun test",
    "tests:watch": "bun test --watch",
    "tests:dist": "bun run build && TEST_DIST=true bun test"
  },
  "peerDependencies": {
    "turbo": ">=2.0.8"
  },
  "dependencies": {
    "commander": "14.0.3",
    "nano-spawn": "2.0.0",
    "@inquirer/select": "5.1.2"
  },
  "devDependencies": {
    "@yunarch/config-web": "0.7.7",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.19.0",
    "husky": "9.1.7",
    "rimraf": "6.1.3",
    "turbo": "2.8.21",
    "typescript": "6.0.2",
    "@types/node": "25.5.0",
    "@types/bun": "1.3.11"
  },
  "packageManager": "bun@1.3.11"
}
